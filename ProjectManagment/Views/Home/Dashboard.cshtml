@model ProjectManagment.ViewModels.HomeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="app-shell">
    <header class="topbar topbar--compact">
        <a class="brand-mark" href="/">
            <img src="~/images/ding-calendar-logo.png" alt="Ding! Your Calendar logo" />
            <span>
                <strong>Ding!</strong>
                <em>Your Calendar</em>
            </span>
        </a>

        <div class="company-badge">@Model.OrganizationName</div>
    </header>

    <main class="page-stack">
        <section id="authStage" class="surface-card auth-stage">
            <div id="roleSelection" class="stage-panel stage-panel--active">
                <div class="stage-copy">
                    <span class="eyebrow">Step 1</span>
                    <h1>Select how you want to sign in.</h1>
                    <p>Choose Admin or User first. The app will then show the correct login form and, after sign-in, the matching dashboard.</p>
                </div>

                <div class="role-grid">
                    <button type="button" class="role-card" data-role-choice="admin">
                        <img src="~/images/ding-calendar-logo.png" alt="" />
                        <strong>Admin</strong>
                        <span>Manage events, update schedules, and remove outdated items.</span>
                    </button>

                    <button type="button" class="role-card" data-role-choice="user">
                        <img src="~/images/ding-calendar-logo.png" alt="" />
                        <strong>User</strong>
                        <span>Browse upcoming events, open event pages, and view the calendar.</span>
                    </button>
                </div>
            </div>

            <div id="adminLogin" class="stage-panel">
                <div class="login-layout">
                    <div class="stage-copy">
                        <span class="eyebrow">Admin login</span>
                        <h2>Sign in as an administrator.</h2>
                        <p class="company-name">@Model.OrganizationName</p>
                        <p>Use the company or university credentials for event administration.</p>
                    </div>

                    <form class="auth-form auth-form--boxed" data-login-form="admin">
                        <label for="adminEmail">Email</label>
                        <input id="adminEmail" type="email" placeholder="admin@company.edu" required />

                        <label for="adminPassword">Password</label>
                        <input id="adminPassword" type="password" placeholder="Enter your password" required />

                        <div class="action-row">
                            <button type="submit" class="primary-button">Open Admin Dashboard</button>
                            <button type="button" class="ghost-button" data-back-to-role>Select another role</button>
                        </div>
                    </form>
                </div>
            </div>

            <div id="userLogin" class="stage-panel">
                <div class="login-layout">
                    <div class="stage-copy">
                        <span class="eyebrow">User login</span>
                        <h2>Sign in as a user.</h2>
                        <p class="company-name">@Model.OrganizationName</p>
                        <p>Use your company or university email and password to view upcoming events and the calendar.</p>
                    </div>

                    <form class="auth-form auth-form--boxed" data-login-form="user">
                        <label for="userEmail">Email</label>
                        <input id="userEmail" type="email" placeholder="student@university.edu" required />

                        <label for="userPassword">Password</label>
                        <input id="userPassword" type="password" placeholder="Enter your password" required />

                        <div class="action-row">
                            <button type="submit" class="primary-button">Open User Dashboard</button>
                            <button type="button" class="ghost-button" data-back-to-role>Select another role</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <section id="adminDashboard" class="dashboard-panel dashboard-panel--hidden">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Admin Dashboard</span>
                    <h2>Event administration</h2>
                </div>
                <p>Create, edit, and delete events from a single management dashboard after authentication.</p>
            </div>

            <div class="admin-grid">
                <article class="surface-card admin-form-card">
                    <div class="card-header">
                        <h3>Create or edit an event</h3>
                        <span class="status-pill">Admin only</span>
                    </div>

                    <form class="event-form">
                        <label for="eventName">Event name</label>
                        <input id="eventName" type="text" placeholder="Innovation Kickoff" />

                        <label for="eventDescription">Description</label>
                        <textarea id="eventDescription" rows="4" placeholder="Write the event summary, speakers, and call to action."></textarea>

                        <div class="form-row two-columns">
                            <div>
                                <label for="eventPlace">Place</label>
                                <input id="eventPlace" type="text" placeholder="Atrium Hall" />
                            </div>
                            <div>
                                <label for="eventHour">Hour</label>
                                <input id="eventHour" type="time" value="09:00" />
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div>
                                <label for="eventDate">Date</label>
                                <input id="eventDate" type="date" value="2026-04-08" />
                            </div>
                            <div>
                                <label for="eventCategory">Category</label>
                                <select id="eventCategory">
                                    <option>Featured</option>
                                    <option>Academic</option>
                                    <option>Career</option>
                                    <option>Social</option>
                                </select>
                            </div>
                        </div>

                        <div class="action-row">
                            <button type="button" class="primary-button">Create event</button>
                            <button type="button" class="secondary-button">Edit event</button>
                            <button type="button" class="ghost-button danger-button">Delete event</button>
                        </div>
                    </form>
                </article>

                <article class="surface-card admin-list-card">
                    <div class="card-header">
                        <h3>Current event list</h3>
                        <span class="status-pill neutral">@Model.Events.Count events</span>
                    </div>

                    <div class="admin-event-list">
                        @foreach (var calendarEvent in Model.Events)
                        {
                            <div class="admin-event-item">
                                <div>
                                    <strong>@calendarEvent.Title</strong>
                                    <span>@calendarEvent.EventDate.ToString("MMM dd") - @calendarEvent.StartTime.ToString(@"hh\:mm") to @calendarEvent.EndTime.ToString(@"hh\:mm")</span>
                                    <small>@calendarEvent.Location</small>
                                </div>
                                <div class="mini-actions">
                                    <button type="button" class="mini-button">Edit</button>
                                    <button type="button" class="mini-button ghost">Delete</button>
                                </div>
                            </div>
                        }
                    </div>
                </article>
            </div>
        </section>

        <section id="userDashboard" class="dashboard-panel dashboard-panel--hidden">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">User Dashboard</span>
                    <h2>Events and calendar</h2>
                </div>
                <p>Home shows upcoming events, the calendar highlights event days, and event cards open a dedicated detail page in a new tab.</p>
            </div>

            <div class="user-dashboard-shell">
                <aside class="surface-card user-sidebar">
                    <div class="sidebar-brand">
                        <img src="~/images/ding-calendar-logo.png" alt="" />
                        <div>
                            <strong>@Model.OrganizationName</strong>
                            <span>Signed-in user portal</span>
                        </div>
                    </div>

                    <button type="button" class="tab-link is-active" data-tab-target="tab-home">Home</button>
                    <button type="button" class="tab-link" data-tab-target="tab-calendar">Calendar</button>
                </aside>

                <div class="user-dashboard-content">
                    <section id="tab-home" class="surface-card tab-panel is-active">
                        <div class="card-header">
                            <h3>Upcoming events</h3>
                            <span class="status-pill">Home tab</span>
                        </div>

                        <div class="upcoming-grid">
                            @foreach (var calendarEvent in Model.Events)
                            {
                                <a class="event-preview @(calendarEvent.Featured ? "featured-card" : string.Empty)"
                                   href="@Url.Action("EventDetails", "Home", new { id = calendarEvent.Id })"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    <span class="preview-tag">@calendarEvent.Category</span>
                                    <strong>@calendarEvent.Title</strong>
                                    <span>@calendarEvent.EventDate.ToString("MMM dd") - @calendarEvent.StartTime.ToString(@"hh\:mm")</span>
                                    <small>@calendarEvent.Location</small>
                                </a>
                            }
                        </div>
                    </section>

                    <section id="tab-calendar" class="surface-card tab-panel">
                        <div class="card-header">
                            <h3>Calendar</h3>
                            <span class="status-pill neutral">Event days highlighted</span>
                        </div>

                        <div class="calendar-shell">
                            <div class="calendar-month">
                                <strong>April 2026</strong>
                                <span>Select an event from Home to open its details page in a new tab.</span>
                            </div>

                            <div class="calendar-grid">
                                @for (var day = 1; day <= 30; day++)
                                {
                                    var hasEvent = Model.Events.Any(e => e.EventDate.Day == day && e.EventDate.Month == 4);
                                    <div class="calendar-day @(hasEvent ? "has-event" : string.Empty)">
                                        <span>@day</span>
                                        @if (hasEvent)
                                        {
                                            <small>Event</small>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <script>
        (() => {
            const roleSelection = document.getElementById("roleSelection");
            const adminLogin = document.getElementById("adminLogin");
            const userLogin = document.getElementById("userLogin");
            const authStage = document.getElementById("authStage");
            const adminDashboard = document.getElementById("adminDashboard");
            const userDashboard = document.getElementById("userDashboard");
            const stagePanels = [roleSelection, adminLogin, userLogin];
            const dashboardPanels = [adminDashboard, userDashboard];
            const roleButtons = document.querySelectorAll("[data-role-choice]");
            const backButtons = document.querySelectorAll("[data-back-to-role]");
            const loginForms = document.querySelectorAll("[data-login-form]");
            const tabLinks = document.querySelectorAll("[data-tab-target]");
            const tabPanels = document.querySelectorAll(".tab-panel");

            const showStage = (panel) => {
                stagePanels.forEach((item) => item.classList.toggle("stage-panel--active", item === panel));
            };

            const showDashboard = (panel) => {
                authStage.classList.add("auth-stage--hidden");
                dashboardPanels.forEach((item) => item.classList.toggle("dashboard-panel--hidden", item !== panel));
                window.scrollTo({ top: panel.offsetTop - 18, behavior: "smooth" });
            };

            roleButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    const selectedRole = button.dataset.roleChoice;
                    showStage(selectedRole === "admin" ? adminLogin : userLogin);
                });
            });

            backButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    dashboardPanels.forEach((panel) => panel.classList.add("dashboard-panel--hidden"));
                    authStage.classList.remove("auth-stage--hidden");
                    showStage(roleSelection);
                });
            });

            loginForms.forEach((form) => {
                form.addEventListener("submit", (event) => {
                    event.preventDefault();
                    const inputs = form.querySelectorAll("input");
                    const valid = Array.from(inputs).every((input) => input.value.trim() !== "");

                    if (!valid) {
                        return;
                    }

                    if (form.dataset.loginForm === "admin") {
                        showDashboard(adminDashboard);
                    } else {
                        showDashboard(userDashboard);
                    }
                });
            });

            tabLinks.forEach((link) => {
                link.addEventListener("click", () => {
                    const targetId = link.dataset.tabTarget;
                    tabPanels.forEach((panel) => panel.classList.toggle("is-active", panel.id === targetId));
                    tabLinks.forEach((button) => button.classList.toggle("is-active", button === link));
                });
            });
        })();
    </script>
}
