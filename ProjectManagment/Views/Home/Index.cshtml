@{
    ViewData["Title"] = "Home - Keiser Events";
}

<div class="dashboard-wrapper">
    <aside class="sidebar">
        <div class="logo">✦</div>
        <nav class="nav-menu">
            <a href="#" class="nav-link active">Home</a>
            <a href="#" class="nav-link">Calendar</a>
            <a href="#" class="nav-link">Orgs</a>
            <a href="#" class="nav-item">Profile</a>
        </nav>
    </aside>

    <main class="main-content">
        <section class="column events-column">
            <header>
                <h2 class="panel-title">Upcoming Events</h2>
                <div class="search-bar">
                    <input type="text" class="custom-input" placeholder="Find events...">
                </div>
                <div class="filters">
                    <button class="pill active">All</button>
                    <button class="pill">Academic</button>
                    <button class="pill">Social</button>
                </div>
            </header>

            <div class="event-list">
                <div class="event-card featured" onclick="openDetails('mixer')">
                    <span class="tag">FEATURED</span>
                    <h3>Student Union Mixer</h3>
                    <p>TONIGHT 7 PM • Student Union</p>
                    <button class="save-icon">♥</button>
                </div>

                <div class="event-card" onclick="openDetails('robotics')">
                    <h3>Robotics Workshop</h3>
                    <p>WEDNESDAY • 3 PM • Great Hall</p>
                </div>
            </div>
            <button class="btn-primary">CREATE NEW EVENT</button>
        </section>

        <section class="column details-column">
            <div id="welcome-view" class="detail-view">
                <div class="welcome-card">
                    <h1>¡Bienvenido!</h1>
                    <p>Explora los eventos del campus o gestiona tus actividades desde aquí.</p>
                    <img src="https://illustrations.popsy.co/white/calendar.svg" style="width:200px; margin-top:20px;">
                </div>
            </div>

            <div id="details-mixer" class="detail-view" style="display:none;">
                <h2 class="panel-title">Event Details</h2>
                <div class="event-banner">
                    <img src="https://images.unsplash.com/photo-1511632765486-a01980e01a18?auto=format&fit=crop&w=600" alt="Mixer">
                </div>
                <h3>Student Union Mixer</h3>
                <div class="settings-panel">
                    <div class="setting-item"><span>Smart Reminders</span> <div class="toggle active"></div></div>
                    <div class="setting-item sub"><span>Reminder:</span> <span>1 Day Before</span></div>
                </div>
                <button class="btn-secondary">Sync to Outlook</button>
            </div>

            <div id="details-robotics" class="detail-view" style="display:none;">
                <h2 class="panel-title">Event Details</h2>
                <div class="event-banner">
                    <img src="https://images.unsplash.com/photo-1581092160607-ee22621dd758?auto=format&fit=crop&w=600" alt="Robotics">
                </div>
                <h3>Robotics Club Workshop</h3>
                <p>Learn the basics of Arduino and sensor integration.</p>
                <button class="btn-secondary">Sync to Outlook</button>
            </div>
        </section>

        <section class="column employer-column">
            <h2 class="panel-title">Employer Dashboard</h2>
            <p style="color:var(--accent-purple)">Tech Solutions Inc.</p>
            
            <div class="stats-box">
                <p>Total Engagements</p>
                <div class="stat-value">1,520</div>
                <div class="mini-stats">
                    <span>Views: 980</span>
                    <span>Conv: 12%</span>
                </div>
            </div>

            <div class="post-form">
                <label>Post a New Event</label>
                <input type="text" placeholder="Date & Time" class="dark-input">
                <textarea placeholder="Description" class="dark-input"></textarea>
                <button class="btn-gradient">PUBLISH & TARGET</button>
            </div>
        </section>
    </main>
</div>

@section Scripts {
    <script>
        function openDetails(eventId) {
            // Ocultar bienvenida y otros detalles
            document.getElementById('welcome-view').style.display = 'none';
            document.querySelectorAll('.detail-view').forEach(view => view.style.display = 'none');
            
            // Mostrar el detalle seleccionado
            const target = document.getElementById('details-' + eventId);
            if(target) target.style.display = 'block';

            // Resaltar tarjeta activa
            document.querySelectorAll('.event-card').forEach(card => card.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
        }
    </script>
}